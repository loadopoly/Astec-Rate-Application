# ===========================================
# IPS Freight Platform - Default Configuration
# ===========================================
# This file contains safe defaults for local use.
# The START script copies this to .env automatically on first run.
# To customize settings, edit .env (never commit .env to git).

# -------------------------------------------
# Database
# -------------------------------------------
POSTGRES_USER=ips_user
POSTGRES_PASSWORD=ips_password
POSTGRES_DB=ips_freight
DATABASE_URL=postgresql://ips_user:ips_password@localhost:5432/ips_freight

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# Authentication
# -------------------------------------------
# ⚠️  IMPORTANT: Change JWT_SECRET to a unique random value before sharing with others
# Generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=ips-default-jwt-secret-DO-NOT-USE-IN-PRODUCTION-change-this-value-now
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# -------------------------------------------
# API
# -------------------------------------------
NODE_ENV=production
API_PORT=3001
API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------
# Frontend
# -------------------------------------------
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME=IPS Freight Platform

# -------------------------------------------
# pgAdmin (optional management UI)
# -------------------------------------------
PGADMIN_EMAIL=admin@astec.com
PGADMIN_PASSWORD=admin
