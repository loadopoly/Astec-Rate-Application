# ===========================================
# IPS Freight Platform - Default Configuration
# ===========================================
# These defaults work out-of-the-box with Docker.
# No changes are required to get started.

# -------------------------------------------
# Database
# -------------------------------------------
POSTGRES_USER=ips_user
POSTGRES_PASSWORD=ips_password
POSTGRES_DB=ips_freight
DATABASE_URL=postgresql://ips_user:ips_password@localhost:5432/ips_freight

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# Authentication
# -------------------------------------------
JWT_SECRET=ips-default-jwt-secret-change-me-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# -------------------------------------------
# API
# -------------------------------------------
NODE_ENV=production
API_PORT=3001
API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------
# Frontend
# -------------------------------------------
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME=IPS Freight Platform

# -------------------------------------------
# pgAdmin (optional management UI)
# -------------------------------------------
PGADMIN_EMAIL=admin@astec.com
PGADMIN_PASSWORD=admin
